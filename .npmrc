# Supply-chain hardening.
#
# Save exact versions (no ^/~ ranges) so `npm install <pkg>` can never silently
# widen a version range. Combined with the committed package-lock.json — whose
# every entry carries a SHA-512 integrity hash that `npm ci` verifies — this
# pins the entire dependency tree, direct and transitive.
save-exact=true

# Never write/modify the lockfile implicitly; changes must be deliberate.
package-lock=true

# Fail installs on advisories of high severity or worse.
audit-level=high

# Don't execute install-time scripts from dependencies by default. This blocks a
# common supply-chain attack vector (malicious postinstall scripts). If a build
# tool legitimately needs its install script, allow it explicitly and re-run.
# NOTE: verify the build/install still works after enabling (see below).
ignore-scripts=true
