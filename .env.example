# Google Apps Script Configuration (contact form endpoint — public, inlined into the client build)
# copy this file to .env and add your script URL below
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# Storyblok — BUILD-TIME ONLY for production. Never set a VITE_STORYBLOK_* var in a
# production build: VITE_ vars are inlined into the public client bundle, so a token
# there is world-readable. The blog is prerendered at build time by
# scripts/fetch-blog.mjs, which reads these NON-VITE vars (provide via 1Password / op run):
#   STORYBLOK_PUBLIC_TOKEN   — published-content read (required for prod builds)
#   STORYBLOK_VERSION=draft  — local preview builds only (needs a preview token)
STORYBLOK_PUBLIC_TOKEN=your_storyblok_public_token_here

# Local-only: the /preview Visual Editor routes (client-side) read this. NEVER set it
# for a production build — scripts/assert-no-client-secrets.mjs will fail the build if
# any VITE_STORYBLOK_* var is present, to stop a draft-reading token reaching the bundle.
# VITE_STORYBLOK_ACCESS_TOKEN=your_local_preview_token_here
