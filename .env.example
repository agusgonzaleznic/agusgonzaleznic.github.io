# Cloudflare Turnstile site key (PUBLIC value — safe to inline into the client
# bundle). The contact form posts to the same-origin /api/contact endpoint; a
# Lambda behind CloudFront runs siteverify with the SECRET (never in the client)
# and forwards the message to the Google Apps Script server-side. The Apps Script
# URL is now a Lambda SSM value and no longer ships in the client build.
#
# In CI this comes from the repo variable TURNSTILE_SITE_KEY (see
# .github/workflows/deploy.yml build-env-vars). Leave empty for local dev unless
# you are exercising the widget; without it the widget shows a load error.
VITE_TURNSTILE_SITE_KEY=

# Storyblok — BUILD-TIME ONLY for production. Never set a VITE_STORYBLOK_* var in a
# production build: VITE_ vars are inlined into the public client bundle, so a token
# there is world-readable. The blog is prerendered at build time by
# scripts/fetch-blog.mjs, which reads these NON-VITE vars (provide via 1Password / op run):
#   STORYBLOK_PUBLIC_TOKEN   — published-content read (required for prod builds)
#   STORYBLOK_VERSION=draft  — local preview builds only (needs a preview token)
STORYBLOK_PUBLIC_TOKEN=your_storyblok_public_token_here

# Local-only: the /preview Visual Editor routes (client-side) read this. NEVER set it
# for a production build — scripts/assert-no-client-secrets.mjs will fail the build if
# any VITE_STORYBLOK_* var is present, to stop a draft-reading token reaching the bundle.
# VITE_STORYBLOK_ACCESS_TOKEN=your_local_preview_token_here

# DeepL API Free auth key — BUILD-TIME ONLY, and deliberately NON-VITE so it is
# never inlined into the public client bundle. Drives the i18n machine-translation
# pipeline: scripts/translate.mjs (Lingui PO catalogs) and the blog localization in
# scripts/fetch-blog.mjs. Get a free key at https://www.deepl.com/pro-api (free keys
# end in ":fx" and use api-free.deepl.com — auto-detected by scripts/lib/deepl.mjs).
#
# KEYLESS is the default and is safe: with this unset/empty every i18n step no-ops,
# catalogs stay untranslated and only the English blog-data.json is written, so the
# site ships English-only and unchanged. Machine translation is RAW — LLM post-edit +
# native review must follow before a locale is added to PUBLISHED_LOCALES.
# In CI this comes from the repo SECRET DEEPL_API_KEY (see deploy.yml build-env-vars).
DEEPL_API_KEY=

# Google Analytics 4 measurement ID (public value — safe to inline in the client
# bundle). OPTIONAL: leave empty/unset to disable analytics entirely (no script is
# loaded, the banner stays informational). In CI this comes from the repo variable
# GA_MEASUREMENT_ID (see .github/workflows/deploy.yml).
VITE_GA_MEASUREMENT_ID=

# Google Analytics 4 (optional; PUBLIC value). Empty/unset = analytics fully
# disabled: no banner consent mode, no gtag, no GA section in the Privacy page.
# Activation checklist lives in .github/workflows/deploy.yml (GA_MEASUREMENT_ID).
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
